# ── Google OAuth ─────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Add authorized redirect URI: https://your-vercel-domain.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── NextAuth ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=https://your-vercel-domain.vercel.app

# ── Upstash Redis ─────────────────────────────────────────────────
# Create free instance at: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ── CoinGecko (optional — free tier works without key) ───────────
# COINGECKO_API_KEY=your_key_if_needed
